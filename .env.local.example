# ===== Supabase =====
# انسخ هذا الملف إلى .env.local واملأ القيم من لوحة تحكم Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key
# مفتاح الخدمة (للخادم فقط — لا يُكشف للمتصفح)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== Google Calendar / Meet (V1) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
# refresh token لحساب الأكاديمية (يُخزَّن بعد أول OAuth)
GOOGLE_REFRESH_TOKEN=

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_TIMEZONE=Africa/Cairo
APP_DEFAULT_CURRENCY=EGP
