# ===== قاعدة البيانات (PostgreSQL) =====
# سلسلة اتصال Postgres مُدارة (Neon / Supabase / Vercel Postgres). للإنتاج أضِف sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/elhafazah?sslmode=require

# ===== المصادقة =====
# سرّ قويّ فريد — إلزامي في الإنتاج. ولّده بـ: openssl rand -base64 32
AUTH_SECRET=

# ===== التطبيق =====
# عنوان التطبيق الكامل (يُستخدم في روابط استرجاع كلمة المرور و OAuth)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
APP_TIMEZONE=Africa/Cairo
APP_DEFAULT_CURRENCY=EGP

# ===== المهمة الدورية (دورة حياة الحصص + التذكيرات) =====
# سرّ لحماية /api/cron/tick — يضبطه Vercel Cron تلقائياً في رأس Authorization
CRON_SECRET=

# ===== Google Calendar / Meet (اختياري — لإنشاء روابط Meet تلقائياً) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/google/callback
# يُخزَّن بعد أول OAuth لحساب الأكاديمية
GOOGLE_REFRESH_TOKEN=

# ===== تخزين الملفات =====
# تخزين محلي على القرص — للتطوير فقط. لا يعمل على Vercel serverless (نظام ملفات للقراءة فقط).
# للإنتاج: استخدم تخزين كائنات (Vercel Blob / S3).
# STORAGE_DIR=storage
